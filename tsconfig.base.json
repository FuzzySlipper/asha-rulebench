{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "baseUrl": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": false,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2022",
    "module": "preserve",
    "lib": ["es2022", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "useUnknownInCatchVariables": true,
    "paths": {
      "@asha-rulebench/components": ["libs/components/src/index.ts"],
      "@asha-rulebench/platform": ["libs/platform/src/index.ts"],
      "@asha-rulebench/scenario-viewer": ["libs/scenario-viewer/src/index.ts"],
      "@asha-rulebench/shell": ["libs/shell/src/index.ts"],
      "@asha-rulebench/theme": ["libs/theme/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp", "dist", "coverage"]
}
