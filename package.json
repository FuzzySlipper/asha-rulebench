{
  "name": "asha-rulebench",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "node tools/scripts/serve-live.mjs",
    "init": "node tools/scripts/init-project.mjs",
    "build": "nx run-many -t build --all",
    "lint": "nx run-many -t lint --all",
    "typecheck": "nx run-many -t typecheck --all",
    "test": "vitest run --passWithNoTests",
    "verify": "pnpm run check:pattern && pnpm run generated:check && pnpm run regression:check && pnpm run check:rust-boundaries && pnpm run check:rust-test-ownership && pnpm run check:portable-consumer && pnpm run rust:test && pnpm run check:claims && pnpm run check:docs && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build && pnpm run e2e",
    "check:pattern": "node tools/scripts/check-pattern.mjs",
    "check:rust-boundaries": "node tools/scripts/check-rust-boundaries.mjs",
    "check:rust-test-ownership": "node tools/scripts/check-rust-test-ownership.mjs",
    "check:claims": "node tools/scripts/check-verification-claims.mjs",
    "check:portable-consumer": "node tools/scripts/check-portable-consumer.mjs",
    "check:docs": "node tools/scripts/check-docs-commands.mjs",
    "rust:check": "cargo check --manifest-path rulebench-rs/Cargo.toml",
    "rust:test": "cargo test --manifest-path rulebench-rs/Cargo.toml",
    "rust:host": "cargo run --manifest-path rulebench-rs/Cargo.toml -p rulebench-process-host --bin rulebench_process_host --",
    "generated:check": "node tools/scripts/generated-artifacts.mjs",
    "generated:write": "node tools/scripts/generated-artifacts.mjs --write",
    "regression:check": "cargo run --quiet --manifest-path rulebench-rs/Cargo.toml -p rulebench-fixtures --bin check_regressions --",
    "regression:list": "cargo run --quiet --manifest-path rulebench-rs/Cargo.toml -p rulebench-fixtures --bin check_regressions -- --list",
    "protocol:generate": "node libs/protocol/scripts/generate-api-types.mjs",
    "protocol:check": "node libs/protocol/scripts/check-generated.mjs",
    "catalog:generate": "node libs/transport/scripts/generate-rust-scenario-catalog.mjs",
    "catalog:check": "node libs/transport/scripts/generate-rust-scenario-catalog.mjs --check",
    "catalog:write": "node libs/transport/scripts/generate-rust-scenario-catalog.mjs --write",
    "session:generate": "node libs/transport/scripts/generate-rust-combat-session.mjs",
    "session:check": "node libs/transport/scripts/generate-rust-combat-session.mjs --check",
    "session:write": "node libs/transport/scripts/generate-rust-combat-session.mjs --write",
    "serve:local": "node tools/scripts/serve-local.mjs",
    "e2e": "nx e2e app-e2e",
    "e2e:live": "playwright test --config apps/app-e2e/playwright.config.mts --grep @live"
  },
  "dependencies": {
    "@angular/common": "~21.2.0",
    "@angular/compiler": "~21.2.0",
    "@angular/core": "~21.2.0",
    "@angular/platform-browser": "~21.2.0",
    "@angular/router": "~21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/core": "~21.2.0",
    "@angular-devkit/schematics": "~21.2.0",
    "@angular/build": "~21.2.0",
    "@angular/cli": "~21.2.0",
    "@angular/compiler-cli": "~21.2.0",
    "@angular/language-service": "~21.2.0",
    "@eslint/js": "^9.39.4",
    "@nx/angular": "23.0.1",
    "@nx/devkit": "23.0.1",
    "@nx/eslint": "23.0.1",
    "@nx/eslint-plugin": "23.0.1",
    "@nx/js": "23.0.1",
    "@nx/playwright": "23.0.1",
    "@nx/web": "23.0.1",
    "@nx/workspace": "23.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.12.0",
    "@typescript-eslint/utils": "^8.61.1",
    "angular-eslint": "^21.2.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.4.0",
    "nx": "23.0.1",
    "prettier": "~3.6.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
