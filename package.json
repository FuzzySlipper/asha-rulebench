{
  "name": "asha-rulebench",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "node tools/scripts/serve-live.mjs",
    "init": "node tools/scripts/init-project.mjs",
    "build": "nx run-many -t build --all",
    "lint": "nx run-many -t lint --all",
    "typecheck": "nx run-many -t typecheck --all",
    "test": "vitest run --passWithNoTests",
    "verify": "pnpm run verify:static && pnpm run e2e:gate",
    "verify:change": "node tools/scripts/verify-change.mjs",
    "verify:static": "pnpm run test:validation-scripts && pnpm run check:pattern && pnpm run check:typescript-authority && pnpm run check:rules-language-boundary && pnpm run generated:check && pnpm run check:protocol-compatibility && pnpm run check:rust-boundaries && pnpm run check:rust-test-ownership && pnpm run rust:test && pnpm run check:docs && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build",
    "check:pattern": "node tools/scripts/check-pattern.mjs",
    "check:typescript-authority": "node tools/scripts/check-typescript-authority.mjs",
    "check:rules-language-boundary": "node tools/scripts/check-rules-language-boundary.mjs",
    "check:protocol-compatibility": "node tools/scripts/check-protocol-compatibility.mjs",
    "check:rust-boundaries": "node tools/scripts/check-rust-boundaries.mjs",
    "check:rust-test-ownership": "node tools/scripts/check-rust-test-ownership.mjs",
    "check:docs": "node tools/scripts/check-docs-commands.mjs",
    "rust:check": "cargo check --manifest-path rulebench-rs/Cargo.toml",
    "rust:test": "cargo test --manifest-path rulebench-rs/Cargo.toml",
    "rust:host": "cargo run --manifest-path rulebench-rs/Cargo.toml -p rulebench-process-host --bin rulebench_process_host --",
    "generated:check": "node tools/scripts/generated-artifacts.mjs",
    "generated:write": "node tools/scripts/generated-artifacts.mjs --write",
    "protocol:generate": "node libs/protocol/scripts/generate-api-types.mjs",
    "protocol:check": "node libs/protocol/scripts/check-generated.mjs",
    "serve:local": "node tools/scripts/serve-local.mjs",
    "test:validation-scripts": "node --test tools/scripts/*.test.mjs",
    "e2e": "nx e2e app-e2e",
    "e2e:gate": "playwright test --config apps/app-e2e/playwright.config.mts --grep @gate",
    "e2e:live": "pnpm run e2e:live-artifacts",
    "e2e:live-artifacts": "playwright test --config apps/app-e2e/playwright.config.mts --grep @live-artifact"
  },
  "dependencies": {
    "@angular/common": "~21.2.0",
    "@angular/compiler": "~21.2.0",
    "@angular/core": "~21.2.0",
    "@angular/platform-browser": "~21.2.0",
    "@angular/router": "~21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@asha-rpg/authoring": "github:FuzzySlipper/asha-rpg#ea3e3803d4736268f2a10996a34bc5b8dfefcffc&path:packages/authoring",
    "@asha-rpg/ir": "github:FuzzySlipper/asha-rpg#ea3e3803d4736268f2a10996a34bc5b8dfefcffc&path:packages/ir",
    "@angular-devkit/core": "~21.2.0",
    "@angular-devkit/schematics": "~21.2.0",
    "@angular/build": "~21.2.0",
    "@angular/cli": "~21.2.0",
    "@angular/compiler-cli": "~21.2.0",
    "@angular/language-service": "~21.2.0",
    "@eslint/js": "^9.39.4",
    "@nx/angular": "23.0.1",
    "@nx/devkit": "23.0.1",
    "@nx/eslint": "23.0.1",
    "@nx/eslint-plugin": "23.0.1",
    "@nx/js": "23.0.1",
    "@nx/playwright": "23.0.1",
    "@nx/web": "23.0.1",
    "@nx/workspace": "23.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.12.0",
    "@typescript-eslint/utils": "^8.61.1",
    "angular-eslint": "^21.2.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.4.0",
    "nx": "23.0.1",
    "prettier": "~3.6.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
